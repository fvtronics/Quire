<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.fvtronics.Quire</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Quire</name>
  <summary>Combine and edit PDF files</summary>
  <description>
    <p>Quire is a simple GNOME utility for working with local PDF files without a complex document suite.</p>
    <p>Merge multiple PDFs, organize pages, extract page ranges, split documents, compress files, and edit metadata without sending them to an online service.</p>
  </description>

  <developer id="com.fvtronics">
    <name>Francisco Vásquez Cuevas</name>
  </developer>

  <translation type="gettext">quire</translation>
  <launchable type="desktop-id">com.fvtronics.Quire.desktop</launchable>
  <url type="homepage">https://www.fvtronics.com/en/project/quire</url>
  <url type="bugtracker">https://codeberg.org/fvtronics/quire/issues</url>
  <url type="vcs-browser">https://codeberg.org/fvtronics/quire</url>
  <provides>
    <binary>quire</binary>
  </provides>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>
  <content_rating type="oars-1.1" />

  <screenshots>
    <screenshot type="default">
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.5/data/screenshots/merge.png</image>
      <caption>Merge multiple PDF files into a single document</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.5/data/screenshots/organize.png</image>
      <caption>Reorder and remove pages before saving a new PDF</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.5/data/screenshots/extract.png</image>
      <caption>Extract selected pages into a new document</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.5/data/screenshots/split.png</image>
      <caption>Split a PDF into multiple documents</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.5/data/screenshots/compress.png</image>
      <caption>Compress PDF files for smaller output</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.5/data/screenshots/metadata.png</image>
      <caption>View and edit PDF metadata</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.5/data/screenshots/watermark.png</image>
      <caption>Add a watermark to specific PDF pages</caption>
    </screenshot>
  </screenshots>

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1c71d8</color>
  </branding>

  <releases>
    <release version="0.2.5" date="2026-06-04">
      <description>
        <p>New</p>
        <ul>
          <li>Added a Watermark section</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Improved feedback when fields need attention</li>
        </ul>
      </description>
    </release>
    <release version="0.2.4" date="2026-06-04">
      <description>
        <p>Changes</p>
        <ul>
          <li>Improved icon scalability and shadows</li>
        </ul>
      </description>
    </release>
    <release version="0.2.3" date="2026-06-03">
      <description>
        <p>Changes</p>
        <ul>
          <li>Rename app from Folios to Quire</li>
          <li>Modify app icon</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-06-03">
      <description>
        <p>New</p>
        <ul>
          <li>Added an undo action for clearing the document list in the merge section</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Improved app usability in small windows</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-06-02">
      <description>
        <p>Changes</p>
        <ul>
          <li>Improved keyboard navigation throughout the app</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-06-01">
      <description>
        <p>New</p>
        <ul>
          <li>Added undo options when removing PDFs, clearing the merge list, removing pages, or resetting the page order</li>
          <li>Added an option to open keyboard shortcuts from the app menu</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Fixed right-click menus sometimes becoming unavailable</li>
        </ul>
        <p>Optimizations</p>
        <ul>
          <li>Improved responsiveness when reordering PDFs and pages in large documents</li>
        </ul>
      </description>
    </release>
    <release version="0.1.9" date="2026-05-31">
      <description>
        <p>Optimizations</p>
        <ul>
          <li>Improved preview sizing in list and grid views</li>
          <li>Improved responsiveness when working with large PDFs</li>
          <li>Preserved the scroll position while editing items in list and grid views</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
