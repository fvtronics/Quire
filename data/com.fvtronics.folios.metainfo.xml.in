<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.fvtronics.folios</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Folios</name>
  <summary>Combine and edit PDF files</summary>
  <description>
    <p>Folios is a simple GNOME utility for working with local PDF files without a complex document suite.</p>
    <p>Merge multiple PDFs, organize pages, extract page ranges, split documents, and compress files without sending them to an online service.</p>
  </description>

  <developer id="com.fvtronics">
    <name>Francisco Vásquez Cuevas</name>
  </developer>

  <translation type="gettext">folios</translation>
  <launchable type="desktop-id">com.fvtronics.folios.desktop</launchable>
  <url type="homepage">https://gitlab.com/fvtronics/folios</url>
  <url type="bugtracker">https://gitlab.com/fvtronics/folios/-/issues</url>
  <url type="vcs-browser">https://gitlab.com/fvtronics/folios</url>
  <provides>
    <binary>folios</binary>
  </provides>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>
  <content_rating type="oars-1.1" />

  <screenshots>
    <screenshot type="default">
      <image>https://gitlab.com/fvtronics/folios/-/raw/master/data/screenshots/merge.png</image>
      <caption>Merge multiple PDF files into a single document</caption>
    </screenshot>
    <screenshot>
      <image>https://gitlab.com/fvtronics/folios/-/raw/master/data/screenshots/organize.png</image>
      <caption>Reorder and remove pages before saving a new PDF</caption>
    </screenshot>
    <screenshot>
      <image>https://gitlab.com/fvtronics/folios/-/raw/master/data/screenshots/extract.png</image>
      <caption>Extract selected pages into a new document</caption>
    </screenshot>
    <screenshot>
      <image>https://gitlab.com/fvtronics/folios/-/raw/master/data/screenshots/split.png</image>
      <caption>Split a PDF into multiple documents</caption>
    </screenshot>
  </screenshots>

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1c71d8</color>
  </branding>

  <releases>
    <release version="0.1.3" date="2026-05-21">
      <description translate="no">
        <p>New</p>
        <ul>
          <li>Added support for opening and processing password-protected PDFs</li>
          <li>Added advanced output options for normalizing page sizes and removing metadata</li>
        </ul>
        <p>Optimizations</p>
        <ul>
          <li>Updated the PDF backend and platform dependencies for GNOME 50</li>
          <li>Improved internal code organization for easier maintenance</li>
        </ul>
      </description>
    </release>
    <release version="0.1.2" date="2026-05-20">
      <description translate="no">
        <p>New</p>
        <ul>
          <li>Refreshed the application icon and screenshots</li>
        </ul>
        <p>Optimizations</p>
        <ul>
          <li>Improved consistency across the PDF tools</li>
          <li>Made file handling behavior more reliable</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Improved page selection in the extract tool</li>
          <li>Updated the app structure for easier future maintenance</li>
        </ul>
      </description>
    </release>
    <release version="0.1.1" date="2026-05-20">
      <description translate="no">
        <p>New</p>
        <ul>
          <li>Added page rotation to merge, organize, and extract pages</li>
        </ul>
        <p>Optimizations</p>
        <ul>
          <li>Made preview loading more consistent across tabs</li>
          <li>Improved temporary file handling</li>
          <li>Refactored shared PDF helpers to reduce duplicated code</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Updated the compress tool icon</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-05-18">
      <description translate="no">
        <p>Initial version with the core PDF tools.</p>
        <ul>
          <li>Add a native GTK and libadwaita application shell.</li>
          <li>Add tools to merge, organize, extract, split, and compress PDFs.</li>
          <li>Add page previews, list and grid views, reordering, and drag-and-drop where useful.</li>
          <li>Add local output actions for generated PDFs and split output folders.</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
