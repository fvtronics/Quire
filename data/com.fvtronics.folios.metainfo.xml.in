<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.fvtronics.folios</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Folios</name>
  <summary>Merge PDFs locally</summary>
  <description>
    <p>Folios is a simple GNOME utility for everyday PDF tasks, starting with a calm workflow for merging local PDF files into a new document.</p>
    <p>The first version focuses on merging local PDF files into a new document.</p>
  </description>

  <developer id="com.fvtronics">
    <name>Francisco Vásquez Cuevas</name>
  </developer>

  <translation type="gettext">folios</translation>
  <launchable type="desktop-id">com.fvtronics.folios.desktop</launchable>
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1c71d8</color>
  </branding>

  <releases>
    <release version="0.1.0" date="2026-05-18">
      <description translate="no">
        <p>Initial minimal version.</p>
        <ul>
          <li>Add a native GTK and libadwaita application shell.</li>
          <li>Add a simple PDF merge workflow.</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
