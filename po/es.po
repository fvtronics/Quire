msgid "Folios"
msgstr "Folios"

#: data/com.fvtronics.folios.desktop.in:8
msgid "PDF;Merge;Document;GTK;"
msgstr "PDF;Combinar;Documento;GTK;"

#: data/com.fvtronics.folios.metainfo.xml.in:8
msgid "Work with PDFs locally"
msgstr "Trabajar con archivos PDF localmente"

#: data/com.fvtronics.folios.metainfo.xml.in:10
msgid ""
"Folios is a simple GNOME utility for working with local PDF files without a "
"complex document suite."
msgstr ""
"Folios es una utilidad sencilla de GNOME para trabajar con archivos PDF "
"locales sin una suite de documentos compleja."

#: data/com.fvtronics.folios.metainfo.xml.in:11
msgid ""
"Merge multiple PDFs, organize pages, extract page ranges, split documents, "
"and compress files without sending them to an online service."
msgstr ""
"Combina varios PDF, organiza páginas, extrae rangos de páginas, divide "
"documentos y comprime archivos sin enviarlos a un servicio en línea."

#: data/com.fvtronics.folios.metainfo.xml.in:15
msgid "Francisco Vásquez Cuevas"
msgstr "Francisco Vásquez Cuevas"

