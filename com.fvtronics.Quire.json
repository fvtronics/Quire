{
	"id": "com.fvtronics.Quire",
	"runtime": "org.gnome.Platform",
	"runtime-version": "50",
	"sdk": "org.gnome.Sdk",
	"sdk-extensions": [
		"org.freedesktop.Sdk.Extension.rust-stable"
	],
	"command": "quire",
	"finish-args": [
		"--share=ipc",
		"--socket=fallback-x11",
		"--device=dri",
		"--socket=wayland"
	],
	"build-options": {
		"append-path": "/usr/lib/sdk/rust-stable/bin",
		"env": {
			"CARGO_NET_OFFLINE": "true"
		}
	},
	"cleanup": [
		"/include",
		"/lib/pkgconfig",
		"/man",
		"/share/doc",
		"/share/gtk-doc",
		"/share/man",
		"/share/pkgconfig",
		"*.la",
		"*.a"
	],
	"modules": [
		{
			"name": "blueprint-compiler",
			"buildsystem": "meson",
			"cleanup": [
				"*"
			],
			"sources": [
				{
					"type": "archive",
					"url": "https://download.gnome.org/sources/blueprint-compiler/0.20/blueprint-compiler-0.20.4.tar.xz",
					"sha256": "1f1ecc84bcd698902d422f7de83d39229a209dd3016f6d2c3b0ed0ab123f6891"
				}
			]
		},
		{
			"name": "poppler",
			"buildsystem": "cmake-ninja",
			"builddir": true,
			"config-opts": [
				"-DBUILD_GTK_TEST=OFF",
				"-DBUILD_QT5_TESTS=OFF",
				"-DBUILD_QT6_TESTS=OFF",
				"-DBUILD_CPP_TESTS=OFF",
				"-DBUILD_MANUAL_TESTS=OFF",
				"-DRUN_GPERF_IF_PRESENT=OFF",
				"-DENABLE_GOBJECT_INTROSPECTION=OFF",
				"-DENABLE_UTILS=OFF",
				"-DENABLE_CPP=OFF",
				"-DENABLE_GLIB=ON",
				"-DENABLE_LIBOPENJPEG=openjpeg2",
				"-DENABLE_BOOST=OFF",
				"-DENABLE_NSS3=OFF",
				"-DENABLE_GPGME=OFF",
				"-DENABLE_QT5=OFF",
				"-DENABLE_QT6=OFF"
			],
			"sources": [
				{
					"type": "archive",
					"url": "https://poppler.freedesktop.org/poppler-26.05.0.tar.xz",
					"sha256": "6fef27ff04f37db43054c86bcdff6128c9fb1f6af4ef3c8b369a7e9abd68d0bb"
				}
			]
		},
		{
			"name": "quire",
			"builddir": true,
			"buildsystem": "meson",
			"sources": [
				{
					"type": "git",
					"url": "https://codeberg.org/fvtronics/quire.git",
					"tag": "v0.2.5"
				},
				"cargo-sources.json"
			],
			"config-opts": [
				"--libdir=lib",
				"-Dbuildtype=release",
				"-Dcargo-home=/run/build/quire/cargo"
			]
		}
	]
}
